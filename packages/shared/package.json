{
  "name": "@snappin/shared",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "prettier": "@snappin/prettier-config",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types/*": "./src/types/*",
    "./lib/*": "./src/lib/*",
    "./constants/*": "./src/constants/*"
  },
  "devDependencies": {
    "@snappin/eslint-config": "workspace:*",
    "@snappin/prettier-config": "workspace:*",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "prettier": "^3.7.4"
  }
}
