{
  "extends": "@snappin/typescript-config/nextjs",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@snappin/design-system": ["../../packages/design-system/src/ui/index.ts"],
      "@snappin/design-system/*": ["../../packages/design-system/src/*"],
      "@snappin/shared/*": ["../../packages/shared/src/*"]
    },
    "types": ["node", "jest"]
  },
  "include": [
    "./next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "**/*.stories.tsx"]
}
